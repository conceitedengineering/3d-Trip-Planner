{
  "name": "@tools/gtfs-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test --ext .ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "build": "tsc -p tsconfig.build.json",
    "pipeline": "node dist/src/index.js"
  },
  "dependencies": {
    "@packages/transit-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.15"
  }
}
